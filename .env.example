# Backend Environment Variables

# Base de datos
URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Node Environment
NODE_ENV=production

# Backend URL (para los valores que se guardan como URLs públicas)
BACKEND_URL=https://pdfs-bakend.vercel.app

# OpenAI API (requerida para el chatbot de IA)
OPENAI_API_KEY=sk-proj-tu_openai_api_key_aqui

# Stripe (si lo usas)
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Email (si lo usas)
SENDGRID_API_KEY=SG.xxxxx

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Nota sobre imágenes:
# El sistema ahora usa ChatGPT-4 para proporcionar URLs reales de imágenes directamente.
# No se requieren APIs externas adicionales.

# OpenAI
OPENAI_API_KEY=sk-xxxxx

# Vercel specific
VERCEL=1
VERCEL_ENV=production

# Ollama (para IA)
OLLAMA_API_URL=http://localhost:11434

# Logs
LOG_LEVEL=debug
